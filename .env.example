# Copy to .env and adjust if needed: cp .env.example .env

# Database backend: mysql (default) or mongodb
DB_TYPE=mysql

# MySQL (docker-compose service: db)
MYSQL_ROOT_PASSWORD=portfolio_root
MYSQL_DATABASE=portfolio
MYSQL_PORT=3306

# App database connection (used by portfolio app container)
DB_HOST=db
DB_PORT=3306
DB_USER=root
DB_PASSWORD=portfolio_root
DB_NAME=portfolio

# MongoDB (docker-compose service: mongo) — set DB_TYPE=mongodb to use
MONGODB_URI=mongodb://mongo:27017
MONGODB_DB=portfolio
MONGO_PORT=27017

# App server (use 3000; PORT=0 is treated as default 3000 at runtime)
PORT=3000
APP_PORT=3000

# Optional: wait for MySQL on startup (Docker)
DB_CONNECT_RETRIES=15
DB_CONNECT_DELAY_MS=2000

# Logging: debug | info | warn | error
LOG_LEVEL=info
