# Copy to .env in this folder (parent of public/)
# On shared hosting: /home/.../portfolio/api/.env

DB_TYPE=mysql

# cPanel / shared hosting MySQL credentials
DB_HOST=localhost
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=your_db_name

# Shared hosting: do NOT create database (cPanel already created it)
DB_CREATE_DATABASE=false

# Subdirectory deploy (optional — auto-detected if omitted)
# URL: https://patilweb.com/portfolio/api/...  →  APP_BASE_PATH=/portfolio
# APP_BASE_PATH=/portfolio

LOG_LEVEL=info
